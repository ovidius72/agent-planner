{
  "name": "agent-plan-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "check": "tsc -b",
    "build": "tsc -b --clean && tsc -b && pnpm build:web-ui",
    "clean": "tsc -b --clean",
    "build:web-ui": "pnpm --filter @agent-plan/web-ui build",
    "dev:web": "pnpm --filter @agent-plan/web-ui dev",
    "dev:server": "node packages/plan-server/dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
