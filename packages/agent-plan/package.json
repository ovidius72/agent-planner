{
  "name": "agent-plan",
  "version": "0.2.1",
  "private": false,
  "description": "CLI for Agent Plan: project initialization, Claude Code setup, export, and MCP server startup.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-plan": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ovidius72/agent-planner.git"
  },
  "homepage": "https://github.com/ovidius72/agent-planner#readme",
  "bugs": {
    "url": "https://github.com/ovidius72/agent-planner/issues"
  },
  "keywords": [
    "planner",
    "mcp",
    "claude-code",
    "ai-agent",
    "project-planning"
  ],
  "dependencies": {
    "@agent-plan/core": "workspace:*",
    "@agent-plan/mcp": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  }
}
