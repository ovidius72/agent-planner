{
  "name": "@agent-plan/server",
  "version": "0.2.10",
  "private": false,
  "description": "Local HTTP/WebSocket server for Agent Plan dashboards and planner APIs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./serve": "./dist/serve.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ovidius72/agent-planner.git"
  },
  "homepage": "https://github.com/ovidius72/agent-planner#readme",
  "bugs": {
    "url": "https://github.com/ovidius72/agent-planner/issues"
  },
  "keywords": [
    "planner",
    "server",
    "websocket",
    "dashboard",
    "ai-agent"
  ],
  "dependencies": {
    "@agent-plan/core": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  }
}
