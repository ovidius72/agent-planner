{
  "name": "@agent-plan/core",
  "version": "0.2.2",
  "private": false,
  "description": "Harness-agnostic core for Agent Plan: schemas, persistence, ordering, status rollups, and markdown rendering.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js",
    "./naming": "./dist/naming.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ovidius72/agent-planner.git"
  },
  "homepage": "https://github.com/ovidius72/agent-planner#readme",
  "bugs": {
    "url": "https://github.com/ovidius72/agent-planner/issues"
  },
  "keywords": [
    "planner",
    "project-planning",
    "schema",
    "typescript",
    "ai-agent"
  ],
  "dependencies": {
    "zod": "^3.24.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  }
}
