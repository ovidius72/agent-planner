{
  "name": "@agent-plan/mcp",
  "version": "0.2.7",
  "private": false,
  "description": "MCP server for Agent Plan, exposing planner-* tools over stdio.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-plan-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ovidius72/agent-planner.git"
  },
  "homepage": "https://github.com/ovidius72/agent-planner#readme",
  "bugs": {
    "url": "https://github.com/ovidius72/agent-planner/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "planner",
    "claude-code",
    "ai-agent"
  ],
  "dependencies": {
    "@agent-plan/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.17.0",
    "zod": "^3.24.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  }
}
